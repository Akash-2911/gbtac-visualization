# Copy to .env.local for local dev (both are gitignored). CI (see
# .github/workflows/dev_app-gbtac-dev.yml) injects the Dev values directly.

# Backend Azure Functions API base URL
REACT_APP_API_BASE_URL=https://func-gbtac-dev1-g8d8c2c6e6crc2ag.canadacentral-01.azurewebsites.net/api

# Entra ID (MSAL) app registration
REACT_APP_AAD_CLIENT_ID=
REACT_APP_AAD_TENANT_ID=

# Set to "true" to bypass /powerbi/token and use a fake embed token
# (useful for local UI work before the backend Power BI wiring is ready)
REACT_APP_USE_MOCK_EMBED_TOKEN=false

# Power BI — one consolidated report, one page ID per dashboard tab.
# Get these from the report's URL in Power BI Service (reportId is in the
# URL path, pageId is the ?pageName= or bookmark param for that tab).
REACT_APP_PBI_REPORT_ID=
REACT_APP_PBI_PAGE_OVERVIEW=
REACT_APP_PBI_PAGE_ENERGY=
REACT_APP_PBI_PAGE_SOLAR=
REACT_APP_PBI_PAGE_WEATHER=
REACT_APP_PBI_PAGE_EMISSIONS=
REACT_APP_PBI_PAGE_ENERGY_VS_SOLAR=
REACT_APP_PBI_PAGE_ENERGY_SOLAR_BREAKDOWN=
